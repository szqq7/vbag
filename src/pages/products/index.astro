---
import { getEmDashCollection } from "emdash";
import Base from "../../layouts/Base.astro";

const url = new URL(Astro.request.url);
const selectedCategory = url.searchParams.get("category");

const PAGE_SIZE = 12;
const currentPage = Math.max(1, parseInt(url.searchParams.get("page") || "1") || 1);

// ── 总数：D1 直接 COUNT(*)，毫秒级，不传输任何产品 JSON ──
// 失败则降级为「拉全部再统计」（与旧逻辑一致，慢但保证可用）
let total = 0;
try {
  const db = (Astro.locals as any).runtime?.env?.DB;
  if (!db) throw new Error("no-db");
  let sql = `SELECT COUNT(*) AS c FROM ec_products`;
  const args: string[] = [];
  if (selectedCategory) {
    sql = `SELECT COUNT(*) AS c
      FROM ec_products p
      JOIN content_taxonomies ct ON ct.collection = 'products' AND ct.entry_id = p.id
      JOIN taxonomies t ON t.id = ct.taxonomy_id
      WHERE t.name = 'products1' AND t.slug = ?`;
    args.push(selectedCategory);
  }
  const row = await db.prepare(sql).bind(...args).first();
  total = Number((row as any)?.c ?? 0);
  if (!total) throw new Error("zero");
} catch {
  const { entries } = await getEmDashCollection(
    "products",
    selectedCategory ? { where: { products1: selectedCategory } } : {}
  );
  total = (entries || []).length;
}

// ── 当前页数据：只取本页 12 条，绝不全表拉取 ──
const opts: any = { limit: currentPage * PAGE_SIZE, orderBy: { created_at: "desc" } };
if (selectedCategory) opts.where = { products1: selectedCategory };
const { entries } = await getEmDashCollection("products", opts);
const displayProducts = (entries || []).slice((currentPage - 1) * PAGE_SIZE, currentPage * PAGE_SIZE);

const totalPages = Math.max(1, Math.ceil(total / PAGE_SIZE));
const safePage = Math.min(currentPage, totalPages);

function buildPageUrl(page: number): string {
  const u = new URL(url.toString());
  if (page === 1) u.searchParams.delete("page");
  else u.searchParams.set("page", String(page));
  return u.pathname + u.search;
}

function getFirstImage(entry: any) {
  try {
    if (!entry?.data?.picture_json) return "";
    const raw = typeof entry.data.picture_json === "string"
      ? entry.data.picture_json : JSON.stringify(entry.data.picture_json);
    if (!raw || raw === "null" || raw === "{}") return "";
    const parsed = JSON.parse(raw);
    const pics = Array.isArray(parsed) ? parsed : [parsed];
    return pics[0]?.url || pics[0]?.src || pics[0] || "";
  } catch { return ""; }
}

Astro.response.headers.set('Cache-Control', 'public, max-age=0, s-maxage=300');
Astro.response.headers.set('CDN-Cache-Control', 'public, max-age=300, stale-while-revalidate=60');
---

<Base title="Products">
  <div class="products-page">
    <div class="products-grid">
      {displayProducts.map((product) => {
        const imgUrl = getFirstImage(product);
        return (
          <a href={`/products/${product.slug}`} class="product-card">
            <div class="product-image">
              {imgUrl ? (
                <img src={imgUrl} alt={product.data?.title || ""} loading="lazy" />
              ) : (
                <div class="no-image">No Image</div>
              )}
            </div>
            <h3 class="product-title">{product.data?.title}</h3>
          </a>
        );
      })}
    </div>

    {displayProducts.length === 0 && (
      <div class="empty-state">
        <p>{selectedCategory ? "此分类下暂无产品" : "暂无产品"}</p>
      </div>
    )}

    {totalPages > 1 && (
      <nav class="pagination">
        <a href={safePage > 1 ? buildPageUrl(safePage - 1) : '#'}
           class={`pg-btn ${safePage <= 1 ? 'disabled' : ''}`}>‹ Prev</a>
        {Array.from({ length: totalPages }, (_, i) => i + 1).map(p => (
          <a key={p} href={buildPageUrl(p)}
             class={`pg-btn ${p === safePage ? 'active' : ''}`}>{p}</a>
        ))}
        <a href={safePage < totalPages ? buildPageUrl(safePage + 1) : '#'}
           class={`pg-btn ${safePage >= totalPages ? 'disabled' : ''}`}>Next ›</a>
      </nav>
    )}
  </div>
</Base>

<style>
  .products-page { max-width: 1400px; margin: 0 auto; padding: 2rem; }
  .products-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; }
  .product-card { text-decoration: none; color: inherit; transition: transform 0.2s, box-shadow 0.2s; border-radius: 8px; overflow: hidden; background: #fff; border: 1px solid #f0f0f0; }
  .product-card:hover { transform: translateY(-4px); box-shadow: 0 8px 24px rgba(0,0,0,0.08); }
  .product-image { aspect-ratio: 1; background: #f8f9fa; overflow: hidden; display: flex; align-items: center; justify-content: center; }
  .product-image img { width: 100%; height: 100%; object-fit: contain; padding: 1rem; transition: transform 0.3s; }
  .product-card:hover .product-image img { transform: scale(1.03); }
  .no-image { color: #bbb; font-size: 0.9rem; }
  .product-title { font-size: 0.9rem; font-weight: 500; line-height: 1.4; color: #333; padding: 0.75rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; min-height: 3.2em; }
  .empty-state { text-align: center; padding: 5rem 2rem; color: #999; }

  .pagination { display: flex; justify-content: center; align-items: center; gap: 6px; margin-top: 2.5rem; flex-wrap: wrap; }
  .pg-btn {
    display: inline-flex; align-items: center; justify-content: center;
    min-width: 36px; height: 36px; padding: 0 10px;
    border: 1px solid #e0e0e0; border-radius: 4px;
    background: #fff; color: #555;
    font-size: 0.875rem; text-decoration: none;
  }
  .pg-btn:hover:not(.disabled):not(.active) { background: #f5f5f5; border-color: #ccc; color: #06c; }
  .pg-btn.active { background: #5cc4b8; border-color: #5cc4b8; color: #fff; font-weight: 600; cursor: default; }
  .pg-btn.disabled { opacity: 0.4; pointer-events: none; }

  @media (max-width: 1200px) { .products-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 900px) { .products-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 500px) { .products-grid { grid-template-columns: repeat(2, 1fr); gap: 1rem; } }
</style>
