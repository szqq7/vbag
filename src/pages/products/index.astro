---
import Base from "../../layouts/Base.astro";
import {
  loadProduct, getColorOptions, getPricingSteps, getPrintMethodTabs,
  getPrintingSurfaces, getAllImages, getDownloadFiles, getTemplateFiles,
  getSpecifications, type ProductData
} from "../../utils/product-data";

const url = new URL(Astro.request.url);
const requestedCode = url.searchParams.get("code");
const defaultCode = "120356";
const product: ProductData | null = loadProduct(requestedCode || defaultCode);

if (!product) {
  return Astro.redirect("/404");
}

const title: string = product.nameEn || "Product";
const images: string[] = getAllImages(product);
const mainImage: string = images[0] || product.imgMainUrl || "";
const colors = getColorOptions(product);
const pricingSteps = getPricingSteps(product);
const methodTabs = getPrintMethodTabs(product);
const surfaces = getPrintingSurfaces(product);
const downloadFiles = getDownloadFiles(product);
const templateFiles = getTemplateFiles(product);
const specs = getSpecifications(product);
const description: string = product.descriptionEn || "";
const defaultColor: string = colors.length > 0 ? colors[0].name : "Default";
const setupCharge = 50;
---

<Base title={title}>
  <div class="product-page">
    <!-- 左栏 -->
    <div class="left-column">
      <!-- 媒体区 -->
      <div class="product-media">
        {images.length > 0 && (
          <div class="thumbnails">
            {images.map((img, i) => (
              <button class={`thumb-btn ${i === 0 ? "active" : ""}`} data-src={img}>
                <img src={img} alt="" />
              </button>
            ))}
          </div>
        )}
        <div class="main-image-wrap">
          <img id="mainImg" class="main-image" src={mainImage} alt={title} />
          {!mainImage && <div class="no-image">No Image</div>}
        </div>
      </div>

      <!-- 下载按钮(横排,占满左栏宽度) -->
      <div class="download-row">
        {downloadFiles.length > 0 && (
          <a class="download-btn" href={downloadFiles[0].path} target="_blank" download>
            <svg class="dl-icon" viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6zm-1 7V3.5L18.5 9H13z"/></svg>
            <span>Download Hi-Res Image</span>
          </a>
        )}
        {templateFiles.length > 0 && (
          <a class="download-btn" href={templateFiles[0].path} target="_blank" download>
            <svg class="dl-icon" viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6zm-1 7V3.5L18.5 9H13z"/></svg>
            <span>Download Template</span>
          </a>
        )}
      </div>

      <!-- PRODUCT DESCRIPTION -->
      <section class="description-section">
        <h2>PRODUCT DESCRIPTION</h2>
        <p>{description || "No description available."}</p>
      </section>

      <!-- PRODUCT SPECIFICATIONS -->
      <section class="specs-section">
        <h2>PRODUCT SPECIFICATIONS</h2>
        <table class="specs-table">
          <tbody>
            {specs.map((s) => (<tr><td class="spec-key">{s.label}</td><td class="spec-value">{s.value}</td></tr>))}
          </tbody>
        </table>
      </section>

      <!-- IMPRINT LOCATION(横排两张) -->
      <section class="imprint-diagram-section">
        <h2>IMPRINT LOCATION</h2>
        <p class="imprint-note">The imprint area shown is for dimension and placement reference only. Please contact us if you have any other questions.</p>
        {surfaces.length > 0 ? (
          <div class="imprint-diagram-grid">
            {surfaces.map((s) => {
              const r = s.regions[0];
              const w = r ? r.width : 0;
              const h = r ? r.height : 0;
              return (
                <div class="imprint-card">
                  <svg class="imprint-svg" viewBox="0 0 200 220" xmlns="http://www.w3.org/2000/svg">
                    <rect x="40" y="40" width="120" height="170" fill="none" stroke="#999" stroke-width="2" />
                    <path d="M70 40 Q70 15 100 15 Q130 15 130 40" fill="none" stroke="#999" stroke-width="2" />
                    <line x1="40" y1="55" x2="160" y2="55" stroke="#999" stroke-width="1" />
                    <text x="100" y="135" text-anchor="middle" fill="#666" font-size="11" font-family="Arial">{s.name}</text>
                    <text x="100" y="155" text-anchor="middle" fill="#999" font-size="9" font-family="Arial">W:{w} IN × H:{h} IN</text>
                  </svg>
                  <p class="imprint-summary">{s.name}: W:{w} IN × H:{h} IN</p>
                </div>
              );
            })}
          </div>
        ) : (<p style="color:#999">No imprint location data</p>)}
      </section>

      <section class="ordering-section">
        <h2>ORDERING PROCESS</h2>
        <p class="ordering-text">Product Ordering Process <a href="#" class="view-link">View</a></p>
      </section>
    </div>

    <!-- 右栏 -->
    <div class="right-column">
      <div class="product-info">
        <h1 class="product-title">{title}</h1>

        <div class="color-header">
          <span class="color-label">PRODUCT COLOR: <strong id="currentColor">{defaultColor}</strong></span>
          <label class="bulk-toggle">
            <span>Bulk order: Min colors</span>
            <input type="checkbox" />
            <span class="toggle-track"><span class="toggle-thumb"></span></span>
          </label>
        </div>

        {colors.length > 0 && (
          <div class="color-grid">
            {colors.map((c, i) => (
              <button class={`color-swatch ${i === 0 ? "selected" : ""}`} style={`background-color:${c.rgb};`} data-name={c.name} data-img={c.imageUrl || ""} title={c.name}></button>
            ))}
          </div>
        )}

        <div class="method-section">
          <h3 class="section-title">IMPRINT METHOD & QUANTITY</h3>
          <div class="tabs">
            {methodTabs.map((tab, i) => (
              <button class={`tab-btn ${i === 0 ? "active" : ""}`} data-method={tab.name}>{tab.name}</button>
            ))}
          </div>
          {pricingSteps.length > 0 && (
            <div class="pricing-table">
              <div class="pricing-row header">
                <span class="qty-col">Quantity</span>
                {pricingSteps.map((s) => (<span class="step-col">{s.label}</span>))}
              </div>
              <div class="pricing-row values" id="pricingRow">
                <span class="qty-col">Price Each (C)</span>
                {pricingSteps.map((s) => (<span class="step-col" data-step-price={s.price}>{s.formatted}</span>))}
              </div>
            </div>
          )}
          <a class="flat-price-link" href="#">Sign in to view flat price</a>
        </div>

        <div class="quantity-section">
          <label>Enter the quantity you'd like</label>
          <div class="qty-input-group">
            <button type="button" id="qtyMinus">−</button>
            <input type="number" id="qtyInput" value="50" min="1" />
            <button type="button" id="qtyPlus">+</button>
            <span id="qtyTotal" class="qty-total">$0.00</span>
          </div>
        </div>

        <h3 class="section-title">IMPRINT LOCATION(S) & OPTION</h3>
        <div class="imprint-locations">
          {surfaces.length > 0 ? (
            surfaces.map((s, i) => (
              <label class="imprint-checkbox">
                <input type="checkbox" checked={i === 0} />
                <span>{s.name}</span>
              </label>
            ))
          ) : (<span style="color:#999">No imprint location info</span>)}
        </div>
        <div class="imprint-color">
          <label>Imprint Color</label>
          <select><option>1 color</option><option>2 color</option><option>3 color</option></select>
        </div>
        <div class="custom-color">
          <label>Enter your preferred color besides the colors listed above</label>
          <div class="custom-color-group">
            <input type="text" placeholder="e.g. Neon Green" />
            <button type="button">+ Add</button>
          </div>
        </div>

        <label class="sample-checkbox">
          <input type="checkbox" />
          <span>Physical Sample: <strong>Send me a physical sample</strong></span>
        </label>

        <div class="zip-code">
          <label>ZIP Code</label>
          <div class="zip-row">
            <input type="text" id="zipInput" placeholder="Enter ZIP Code for shipping estimate." />
            <label class="zip-residential"><input type="checkbox" /><span>Residential Address</span></label>
          </div>
        </div>

        <!-- 价格明细 -->
        <div class="pricing-summary">
          <a href="#" class="view-delivery-time">View Delivery Time</a>
          <table class="summary-table">
            <tbody>
              <tr>
                <td><span id="summaryQty">$1.80 (C) ea × 50 qty</span></td>
                <td class="summary-right" id="summarySubtotal">$90.00</td>
              </tr>
              <tr>
                <td>Set-Up Charge (G)</td>
                <td class="summary-right">${setupCharge}.00</td>
              </tr>
              <tr>
                <td>Shipping Charge</td>
                <td class="summary-right" id="summaryShipping">Please enter ZIP Code</td>
              </tr>
              <tr class="total-row">
                <td><strong>Total</strong></td>
                <td class="summary-right"><strong id="summaryTotal">$140.00</strong></td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</Base>

<script is:inline define:vars={{ pricingSteps, methodTabs, setupCharge }}>
  window.__PS__ = pricingSteps;
  window.__MT__ = methodTabs;
  window.__SETUP__ = setupCharge;
</script>

<script>
document.querySelectorAll(".thumb-btn").forEach(function(b){
  b.addEventListener("click", function(){
    var s = this.getAttribute("data-src");
    var m = document.getElementById("mainImg");
    if (m && s) m.src = s;
    document.querySelectorAll(".thumb-btn").forEach(function(x){ x.classList.remove("active"); });
    this.classList.add("active");
  });
});
document.querySelectorAll(".color-swatch").forEach(function(s){
  s.addEventListener("click", function(){
    document.querySelectorAll(".color-swatch").forEach(function(x){ x.classList.remove("selected"); });
    this.classList.add("selected");
    var n = this.getAttribute("data-name");
    var i = this.getAttribute("data-img");
    var l = document.getElementById("currentColor");
    if (l && n) l.textContent = n;
    if (i) {
      var m = document.getElementById("mainImg");
      if (m) m.src = i;
    }
  });
});
function getCS(){
  var a = document.querySelector(".tab-btn.active");
  var n = a ? a.getAttribute("data-method") : "Screen Print";
  var tabs = window.__MT__ || [];
  for (var i = 0; i < tabs.length; i++) {
    if (tabs[i].name === n && tabs[i].pricingSteps && tabs[i].pricingSteps.length > 0) {
      return tabs[i].pricingSteps;
    }
  }
  return window.__PS__ || [];
}
function getUnitPrice(qty){
  var s = getCS().slice().sort(function(a,b){ return b.num - a.num; });
  for (var i = 0; i < s.length; i++) {
    if (qty >= s[i].num) return parseFloat(s[i].price);
  }
  return 0;
}
document.querySelectorAll(".tab-btn").forEach(function(b){
  b.addEventListener("click", function(){
    document.querySelectorAll(".tab-btn").forEach(function(x){ x.classList.remove("active"); });
    this.classList.add("active");
    recalc();
  });
});
function recalc(){
  var q = document.getElementById("qtyInput");
  var qtyTotal = document.getElementById("qtyTotal");
  var summaryQty = document.getElementById("summaryQty");
  var summarySubtotal = document.getElementById("summarySubtotal");
  var summaryTotal = document.getElementById("summaryTotal");
  if (!q) return;
  var n = Math.max(0, parseInt(q.value) || 0);
  var unit = getUnitPrice(n);
  var subtotal = unit * n;
  var setup = window.__SETUP__ || 50;
  var total = subtotal + setup;
  if (qtyTotal) qtyTotal.textContent = "$" + subtotal.toFixed(2);
  if (summaryQty) summaryQty.textContent = "$" + unit.toFixed(2) + " (C) ea × " + n + " qty";
  if (summarySubtotal) summarySubtotal.textContent = "$" + subtotal.toFixed(2);
  if (summaryTotal) summaryTotal.textContent = "$" + total.toFixed(2);
}
var qm = document.getElementById("qtyMinus");
if (qm) qm.addEventListener("click", function(){
  var i = document.getElementById("qtyInput");
  if (!i) return;
  var v = parseInt(i.value) || 1;
  if (v > 1) i.value = String(v - 1);
  recalc();
});
var qp = document.getElementById("qtyPlus");
if (qp) qp.addEventListener("click", function(){
  var i = document.getElementById("qtyInput");
  if (!i) return;
  i.value = String((parseInt(i.value) || 0) + 1);
  recalc();
});
var qi = document.getElementById("qtyInput");
if (qi) qi.addEventListener("input", recalc);

var zipEl = document.getElementById("zipInput");
if (zipEl) zipEl.addEventListener("input", function(){
  var summaryShipping = document.getElementById("summaryShipping");
  var summaryTotal = document.getElementById("summaryTotal");
  if (!summaryShipping) return;
  var zip = zipEl.value.trim();
  if (zip === "") {
    summaryShipping.textContent = "Please enter ZIP Code";
    summaryShipping.style.color = "red";
    recalc();
  } else if (!/^\d{5}$/.test(zip)) {
    summaryShipping.textContent = "Invalid ZIP Code";
    summaryShipping.style.color = "red";
    recalc();
  } else {
    var n = parseInt(document.getElementById("qtyInput").value) || 0;
    var ship = n * 0.5;
    summaryShipping.textContent = "$" + ship.toFixed(2);
    summaryShipping.style.color = "#222";
    var unit = getUnitPrice(n);
    var subtotal = unit * n;
    var setup = window.__SETUP__ || 50;
    var total = subtotal + setup + ship;
    if (summaryTotal) summaryTotal.textContent = "$" + total.toFixed(2);
  }
});

recalc();
</script>

<style>
.product-page { display: grid; grid-template-columns: 540px 1fr; gap: 3.5rem; max-width: 1400px; margin: 0 auto; padding: 2.5rem; }
.left-column { display: flex; flex-direction: column; gap: 1.5rem; }
.right-column { }

.product-media { display: flex; flex-direction: row; gap: 14px; align-items: flex-start; }
.thumbnails { display: flex; flex-direction: column; gap: 10px; width: 90px; flex-shrink: 0; max-height: 600px; overflow-y: auto; }
.thumb-btn { width: 90px; height: 90px; padding: 2px; border: 1px solid #e0e0e0; border-radius: 4px; background: #fff; cursor: pointer; overflow: hidden; }
.thumb-btn.active { border-color: #333; }
.thumb-btn img { width: 100%; height: 100%; object-fit: cover; display: block; }
.main-image-wrap { flex: 1; aspect-ratio: 1; background: #f8f9fa; border: 1px solid #eee; border-radius: 4px; display: flex; align-items: center; justify-content: center; overflow: hidden; min-height: 450px; }
.main-image { width: 100%; height: 100%; object-fit: contain; padding: 1.5rem; }
.no-image { color: #999; }

/* 下载按钮 - 横排,占满左栏 */
.download-row { display: flex; flex-direction: row; gap: 12px; width: 100%; }
.download-btn {
  flex: 1; display: flex; align-items: center; justify-content: center;
  gap: 8px; padding: .75rem 1rem;
  border: 1px solid #0066c0; color: #0066c0;
  border-radius: 4px; text-decoration: none;
  font-size: .9rem; font-weight: 500;
  transition: background .15s, color .15s;
  white-space: nowrap;
}
.download-btn:hover { background: #0066c0; color: #fff; }
.dl-icon { flex-shrink: 0; }

.description-section, .specs-section, .imprint-diagram-section, .ordering-section { margin-bottom: 0; }
.description-section h2, .specs-section h2, .imprint-diagram-section h2, .ordering-section h2 { font-size: 1.1rem; font-weight: 700; margin: 0 0 1rem; padding-bottom: .5rem; border-bottom: 2px solid #111; color: #222; }
.description-section p { font-size: .95rem; line-height: 1.7; color: #444; margin: 0; }
.specs-table { width: 100%; border-collapse: collapse; }
.specs-table tr { border-bottom: 1px solid #e8e8e8; }
.specs-table td { padding: .85rem .5rem; font-size: .95rem; vertical-align: top; }
.spec-key { width: 35%; color: #555; font-weight: 500; }
.spec-value { color: #222; }
.imprint-note { font-size: .85rem; color: #666; margin: 0 0 1.5rem; }

/* IMPRINT LOCATION - 横排两张图 */
.imprint-diagram-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
.imprint-card { text-align: center; }
.imprint-svg { width: 100%; max-width: 200px; height: auto; display: block; margin: 0 auto; }
.imprint-summary { font-size: .85rem; color: #333; margin: .5rem 0 0; }

.ordering-text { font-size: .95rem; color: #444; margin: 0; }
.view-link { color: #0066c0; text-decoration: none; margin-left: .5rem; }
.view-link:hover { text-decoration: underline; }

.product-info { padding-top: 0; }
.product-title { font-size: 1.6rem; font-weight: 600; margin: 0 0 1rem; line-height: 1.3; color: #111; }
.color-header { display: flex; justify-content: space-between; align-items: center; font-size: .9rem; color: #555; margin-bottom: .5rem; }
.color-label strong { color: #222; font-weight: 600; }
.bulk-toggle { display: inline-flex; align-items: center; gap: 6px; font-size: .85rem; color: #555; cursor: pointer; }
.bulk-toggle input { display: none; }
.toggle-track { width: 28px; height: 16px; background: #ccc; border-radius: 8px; position: relative; }
.toggle-thumb { width: 12px; height: 12px; background: #fff; border-radius: 50%; position: absolute; top: 2px; left: 2px; }
.bulk-toggle input:checked + .toggle-track { background: #0066c0; }
.bulk-toggle input:checked + .toggle-track .toggle-thumb { transform: translateX(12px); }
.color-grid { display: grid; grid-template-columns: repeat(10, 1fr); gap: 5px; margin-bottom: 1.5rem; }
.color-swatch { width: 100%; aspect-ratio: 1; border: 1px solid #d0d0d0; border-radius: 2px; cursor: pointer; min-height: 26px; padding: 0; }
.color-swatch.selected { border: 2px solid #333; box-shadow: 0 0 0 1px #fff inset; }
.section-title { font-size: .95rem; font-weight: 700; margin: 0 0 .75rem; color: #222; }
.method-section { margin-bottom: 1rem; }
.tabs { display: flex; border-bottom: 1px solid #ddd; margin-bottom: 1rem; }
.tab-btn { padding: .5rem 1.25rem; border: none; background: none; font-size: .9rem; color: #555; cursor: pointer; border-bottom: 2px solid transparent; }
.tab-btn.active { color: #111; border-bottom-color: #333; font-weight: 600; }
.pricing-table { border: 1px solid #e0e0e0; border-radius: 4px; margin-bottom: .75rem; overflow-x: auto; }
.pricing-row { display: grid; grid-template-columns: 130px repeat(auto-fit, minmax(75px, 1fr)); border-bottom: 1px solid #f0f0f0; }
.pricing-row.header { background: #f8f8f8; font-weight: 600; }
.qty-col, .step-col { padding: .6rem .7rem; text-align: center; border-right: 1px solid #f0f0f0; font-size: .9rem; }
.qty-col { text-align: left; font-weight: 500; color: #333; }
.pricing-row.values .step-col { color: #b12704; }
.flat-price-link { display: inline-block; font-size: .9rem; color: #0066c0; text-decoration: none; margin-bottom: 1.25rem; }
.quantity-section { margin-bottom: 1.5rem; }
.quantity-section label { display: block; font-size: .9rem; color: #555; margin-bottom: .5rem; }
.qty-input-group { display: flex; align-items: center; }
.qty-input-group button { width: 36px; height: 36px; border: 1px solid #ccc; background: #f8f8f8; font-size: 1.1rem; cursor: pointer; }
.qty-input-group input { width: 80px; height: 36px; border: 1px solid #ccc; border-left: none; border-right: none; text-align: center; font-size: 1rem; outline: none; }
.qty-total { padding: 0 1rem; height: 36px; background: #cce8ff; color: #0066c0; display: flex; align-items: center; font-weight: 600; border: 1px solid #ccc; border-left: none; border-radius: 0 4px 4px 0; }
.imprint-locations { display: flex; flex-wrap: wrap; gap: 1.25rem; margin-bottom: 1rem; }
.imprint-checkbox { display: inline-flex; align-items: center; gap: 6px; font-size: .95rem; color: #333; cursor: pointer; }
.imprint-color { margin-bottom: 1.25rem; }
.imprint-color label { display: block; font-size: .9rem; color: #555; margin-bottom: .25rem; }
.imprint-color select { width: 100%; max-width: 200px; padding: .5rem; border: 1px solid #ccc; border-radius: 4px; font-size: .9rem; }
.custom-color { margin-bottom: 1.25rem; }
.custom-color label { display: block; font-size: .9rem; color: #555; margin-bottom: .5rem; }
.custom-color-group { display: flex; gap: 8px; }
.custom-color-group input { flex: 1; max-width: 320px; padding: .5rem; border: 1px solid #ccc; border-radius: 4px; font-size: .9rem; }
.custom-color-group button { padding: .5rem 1.25rem; background: #fff; color: #0066c0; border: 1px solid #0066c0; border-radius: 4px; cursor: pointer; font-size: .9rem; }
.sample-checkbox { display: inline-flex; align-items: center; gap: 8px; font-size: .9rem; color: #444; cursor: pointer; margin-bottom: 1.5rem; }
.zip-code { margin-bottom: .5rem; }
.zip-code label { display: block; font-size: .9rem; color: #555; margin-bottom: .5rem; }
.zip-row { display: flex; gap: 1rem; align-items: center; flex-wrap: wrap; }
.zip-row input[type=text] { flex: 1; min-width: 200px; padding: .5rem .75rem; border: 1px solid #ccc; border-radius: 4px; font-size: .9rem; }
.zip-residential { display: inline-flex; align-items: center; gap: 6px; font-size: .9rem; color: #444; cursor: pointer; }

.pricing-summary { margin-top: 1.5rem; padding-top: 1rem; border-top: 1px solid #e0e0e0; }
.view-delivery-time { display: inline-block; font-size: .9rem; color: #0066c0; text-decoration: none; margin-bottom: .75rem; }
.view-delivery-time:hover { text-decoration: underline; }
.summary-table { width: 100%; border-collapse: collapse; }
.summary-table td { padding: .45rem 0; font-size: .9rem; color: #444; }
.summary-table td.summary-right { text-align: right; color: #222; }
.summary-table .total-row td { padding-top: .75rem; border-top: 1px solid #e8e8e8; font-size: 1rem; }
.summary-table .total-row td.summary-right { color: #111; }

@media (max-width: 1024px) {
  .product-page { grid-template-columns: 1fr; max-width: 800px; padding: 1.5rem; }
  .product-media { flex-direction: column; }
  .thumbnails { flex-direction: row; width: 100%; max-height: none; overflow-x: auto; }
  .download-row { flex-wrap: wrap; }
}
@media (max-width: 640px) {
  .product-page { padding: 1rem; }
  .product-title { font-size: 1.3rem; }
  .color-grid { grid-template-columns: repeat(6, 1fr); }
  .qty-input-group input { width: 60px; }
  .imprint-diagram-grid { grid-template-columns: 1fr; }
}
</style>
