---
export interface Props {
  title: string
  subtitle?: string
  centered?: boolean
  divider?: boolean
}

const { title, subtitle, centered = true, divider = true } = Astro.props
---

<div class="section-header" data-centered={centered}>
  <h2 class="section-title">{title}</h2>
  {subtitle && <p class="section-subtitle">{subtitle}</p>}
  {divider && <div class="section-divider" />}
</div>

<style>
  .section-header[data-centered="true"] { text-align: center; }
  .section-title { font-size: 1.75rem; font-weight: 700; color: #111; margin: 0 0 0.25rem; line-height: 1.2; }
  .section-subtitle { font-size: 0.875rem; color: #6B6B6B; margin: 0 0 0.5rem; line-height: 1.5; }
  .section-divider { width: 40px; height: 2px; background: #22C55E; border-radius: 1px; margin: 0.75rem auto 0; }
  .section-header[data-centered="false"] .section-divider { margin: 0.75rem 0 0; }
</style>
