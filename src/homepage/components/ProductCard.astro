---
interface Product { id: string; title: string; description: string; image: string; link: string; tag?: string }
export interface Props { product: Product }
const { product } = Astro.props
---
<a href={product.link} class="product-card">
  <div class="card-image">
    {product.image ? <img src={product.image} alt={product.title} loading="lazy" /> : <div class="image-placeholder">产品图</div>}
    {product.tag && <span class="card-tag" data-tag={product.tag}>{product.tag}</span>}
  </div>
  <h3 class="card-title">{product.title}</h3>
</a>
<style>
  .product-card {
    display: block;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
    transition: transform 0.2s;
  }
  .product-card:hover {
    transform: translateY(-2px);
  }
  .card-image {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: #F0F0F0;
  }
  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #9B9B9B;
    font-size: 0.8125rem;
    background: #E8E8E8;
  }
  .card-tag {
    position: absolute;
    top: 8px;
    left: 8px;
    font-size: 0.6875rem;
    font-weight: 500;
    padding: 0.125rem 0.5rem;
    border-radius: 4px;
    color: #fff;
  }
  .card-tag[data-tag="热销"] { background: #22C55E; }
  .card-tag[data-tag="新品"] { background: #111; }
  .card-title {
    font-size: 1rem;
    font-weight: 600;
    color: #111;
    margin: 0.75rem 0 0;
    line-height: 1.3;
  }
</style>
